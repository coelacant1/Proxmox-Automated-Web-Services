# PAWS Configuration
# Copy to .env and fill in your values
#
# NOTE: Most settings below can also be configured via the Admin UI after
# running the setup wizard (http://your-host:8000/setup). Values set in the
# Admin UI (stored in the database) take precedence over this .env file.
# The .env file serves as a fallback and is useful for headless/automated
# deployments. For a minimal startup, only the database/redis section and
# PAWS_SECRET_KEY are required; everything else can be configured in the UI.

# JWT Secret - generate with: openssl rand -hex 32
# CRITICAL: Change this before deploying! App will refuse to start in production with the default.
PAWS_SECRET_KEY=CHANGE-ME-IN-PRODUCTION

# Encryption master key for secrets stored in the database (AES-256-GCM)
# Generate with: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# If not set, a key is auto-generated and stored in /data/.paws_master_key
# PAWS_MASTER_KEY=

# --- Single-Cluster Mode (legacy / .env only) ---
# If PAWS_CLUSTER_NAMES is not set, these values define a single cluster named "default".
# Alternatively, configure clusters via Admin UI > Infrastructure > Connections.
# See .InternalDocs/proxmox-token-setup.md for least-privilege token guide
PAWS_PROXMOX_HOST=https://your-proxmox-host
PAWS_PROXMOX_PORT=8006
PAWS_PROXMOX_TOKEN_ID=user@pam!paws
PAWS_PROXMOX_TOKEN_SECRET=your-token-secret-here
PAWS_PROXMOX_VERIFY_SSL=false
PAWS_PROXMOX_PASSWORD=your_root_pam_password_here

# --- Multi-Cluster Mode ---
# Set PAWS_CLUSTER_NAMES to a comma-separated list of cluster names.
# Then define per-cluster vars using PAWS_CLUSTER_{NAME}_* prefix.
#
# PAWS_CLUSTER_NAMES=main,siteb
#
# PAWS_CLUSTER_MAIN_HOST=10.0.0.1
# PAWS_CLUSTER_MAIN_PORT=8006
# PAWS_CLUSTER_MAIN_TOKEN_ID=root@pam!paws
# PAWS_CLUSTER_MAIN_TOKEN_SECRET=your-token-secret
# PAWS_CLUSTER_MAIN_VERIFY_SSL=false
# PAWS_CLUSTER_MAIN_PASSWORD=your-password
# PAWS_CLUSTER_MAIN_PBS_HOST=10.0.0.2
# PAWS_CLUSTER_MAIN_PBS_PORT=8007
# PAWS_CLUSTER_MAIN_PBS_TOKEN_ID=root@pam!paws
# PAWS_CLUSTER_MAIN_PBS_TOKEN_SECRET=your-pbs-secret
# PAWS_CLUSTER_MAIN_PBS_FINGERPRINT=
# PAWS_CLUSTER_MAIN_PBS_DATASTORE=backups
# PAWS_CLUSTER_MAIN_PBS_VERIFY_SSL=false
#
# PAWS_CLUSTER_SITEB_HOST=10.0.1.1
# PAWS_CLUSTER_SITEB_PORT=8006
# PAWS_CLUSTER_SITEB_TOKEN_ID=root@pam!paws
# PAWS_CLUSTER_SITEB_TOKEN_SECRET=your-token-secret
# PAWS_CLUSTER_SITEB_VERIFY_SSL=false
# PAWS_CLUSTER_SITEB_PASSWORD=your-password

# Auth modes (can also be set in Admin UI > System > Auth)
PAWS_LOCAL_AUTH_ENABLED=true
PAWS_OAUTH_ENABLED=true
PAWS_OAUTH_PROVIDER_URL=https://authentik.example.com/application/o
PAWS_OAUTH_CLIENT_ID=
PAWS_OAUTH_CLIENT_SECRET=

# CORS - comma-separated list of allowed origins
PAWS_CORS_ORIGINS=http://localhost:5173

# Rate limiting
PAWS_RATE_LIMIT_PER_MINUTE=100
PAWS_VM_CREATE_LIMIT_PER_HOUR=5
PAWS_AUTH_LOGIN_LIMIT_PER_MINUTE=5
PAWS_AUTH_REGISTER_LIMIT_PER_MINUTE=3

# Password policy
PAWS_PASSWORD_MIN_LENGTH=12
PAWS_PASSWORD_REQUIRE_UPPERCASE=true
PAWS_PASSWORD_REQUIRE_LOWERCASE=true
PAWS_PASSWORD_REQUIRE_DIGIT=true
PAWS_PASSWORD_REQUIRE_SPECIAL=true
PAWS_PASSWORD_HISTORY_COUNT=5

# Default admin account (created on first startup if no admin exists)
# When using the setup wizard (/setup), these are ignored - the wizard
# creates the admin account interactively instead.
PAWS_DEFAULT_ADMIN_USERNAME=admin
PAWS_DEFAULT_ADMIN_EMAIL=admin@paws.local
PAWS_DEFAULT_ADMIN_PASSWORD=changeme

# S3 Storage (Ceph RadosGW) - can also be configured via Admin UI > System > Settings
# See docs/radosgw-setup.md for RadosGW installation and configuration
PAWS_S3_ENDPOINT_URL=http://localhost:7480
PAWS_S3_ACCESS_KEY=your-rgw-access-key
PAWS_S3_SECRET_KEY=your-rgw-secret-key
PAWS_S3_REGION=us-east-1
